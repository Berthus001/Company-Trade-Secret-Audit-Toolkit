# Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
# For local: mongodb://localhost:27017/trade_secret_audit_db
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/trade_secret_audit_db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/trade_secret_audit_db

# JWT Configuration
# Generate a strong random secret (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
